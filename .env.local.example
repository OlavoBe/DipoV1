# ─────────────────────────────────────────────────────────────────
# .env.local — SOMENTE PARA DESENVOLVIMENTO/TESTES
# Este arquivo é gitignored. NUNCA commitá-lo.
# Copie para .env.local e ajuste conforme necessário.
# ─────────────────────────────────────────────────────────────────

# Ativa o modo de testes (login sem magic link em /test-login)
TEST_MODE=true

# Mercado Pago — use as credenciais de TESTE para desenvolvimento
# Produção: substituir pelo Access Token de produção
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxx-xxxx-xxxx

# Modelo LLM para extração de dados (mais barato e rápido)
# Anthropic: claude-3-5-haiku-20241022 | OpenAI: gpt-4o-mini
LLM_MODEL_EXTRACT=gpt-4o-mini

# Modelo LLM para geração de texto formal (mais qualidade)
# Anthropic: claude-sonnet-4-5-20250514 | OpenAI: gpt-4o
LLM_MODEL_GENERATE=gpt-4o
