# Ativa o modo de testes (login sem magic link em /test-login)
TEST_MODE=true

# Mercado Pago — use as credenciais de TESTE para desenvolvimento
# Produção: substituir pelo Access Token de produção
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxx-xxxx-xxxx
