// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Plano {
  DEMO
  TRIAL
  BETA
  PRO_ASSESSOR
  PRO_GABINETE
  CAMARA
}

enum Papel {
  ADMIN
  ASSESSOR
}

// ─────────────────────────────────────────────
// Tenant
// ─────────────────────────────────────────────

model Tenant {
  id           String      @id @default(cuid())
  nome         String
  plano        Plano       @default(DEMO)
  criadoEm     DateTime    @default(now())
  mpCustomerId String?
  planoAtivoEm DateTime?

  // Dados do gabinete (preenchidos no onboarding)
  nomeVereador  String   @default("")
  nomePartido   String   @default("")
  municipio     String   @default("Guarujá")
  nomeAssessor  String   @default("")
  vereadorSlug  String   @default("outro")

  indicacoes Indicacao[]
  templates  Template[]
  users      User[]
}

// ─────────────────────────────────────────────
// Indicacao
// ─────────────────────────────────────────────

model Indicacao {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  inputRaw      String
  extractedJson String
  textoFinal    String
  tipoServico   String
  bairro        String
  logradouro    String
  numero        String?
  cep           String?
  // Feedback do usuário: 1 = positivo, -1 = negativo, null = sem resposta
  feedback      Int?
  feedbackEm    DateTime?

  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
}

// ─────────────────────────────────────────────
// Template
// ─────────────────────────────────────────────

// ─────────────────────────────────────────────
// UsageLog  (métricas do beta)
// ─────────────────────────────────────────────

model UsageLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String   // 'generate' | 'feedback_positive' | 'feedback_negative' | 'download_pdf' | 'download_docx' | 'copy_text' | 'regenerate' | 'ajuste'
  metadata  String?  // JSON opcional com detalhes extras
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────

model Template {
  id        String   @id @default(cuid())
  name      String   @default("default")
  settings  String   // JSON blob com todas as configurações do template
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

// ─────────────────────────────────────────────
// User  (campos NextAuth + campos do sistema)
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  // NextAuth required
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // Sistema
  nome               String?
  papel              Papel    @default(ASSESSOR)
  isAdmin            Boolean  @default(false)
  criadoEm           DateTime @default(now())
  onboardingComplete Boolean  @default(false)

  // Tenant — opcional: usuário existe antes de ser vinculado a um tenant
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])

  accounts      Account[]
  sessions      Session[]
}

// ─────────────────────────────────────────────
// Account  (NextAuth)
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ─────────────────────────────────────────────
// Session  (NextAuth + campos do sistema)
// ─────────────────────────────────────────────

model Session {
  id           String   @id @default(cuid())
  // NextAuth required
  sessionToken String   @unique
  expires      DateTime
  // Sistema
  deviceToken  String   @default("")
  criadoEm    DateTime @default(now())

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// VerificationToken  (NextAuth — magic link)
// ─────────────────────────────────────────────

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// DemoUso  (controle de limite por IP na demo pública)
// ─────────────────────────────────────────────

model DemoUso {
  id       String @id @default(cuid())
  ip       String
  data     String // YYYY-MM-DD
  contagem Int    @default(1)

  @@unique([ip, data])
}
